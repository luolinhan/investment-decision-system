HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# Runtime topology
INVESTMENT_NODE_ROLE=windows_service
INVESTMENT_DATA_SOURCE_MODE=snapshot_first
INVESTMENT_CONTROLLER_HOST=mac-controller
INVESTMENT_COLLECTOR_HOST=aliyun-swas

# Obsidian memory
INVESTMENT_OBSIDIAN_VAULT=/Users/yourname/Documents/Obsidian/KnowledgeBase
OBSIDIAN_VAULT_PATH=

# Lead-Lag V1 sample-data mode
LEAD_LAG_DATA_DIR=sample_data/lead_lag
LEAD_LAG_CONFIG_PATH=config/lead_lag.example.yaml
LEAD_LAG_EXPORT_DIR=reports/lead_lag
LEAD_LAG_USE_SAMPLE_DATA=1

# Bailian runtime APIs
BAILIAN_API_KEY=
BAILIAN_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
BAILIAN_MODEL=qwen3.6-plus
BAILIAN_TIMEOUT_SECONDS=60

# Bailian coding workflow
BAILIAN_PRIMARY_MODEL=glm-5
BAILIAN_SECONDARY_MODEL=qwen3.6-plus
BAILIAN_HIGH_QUOTA_WORKER=
BAILIAN_PREFERRED_WORKER=
BAILIAN_TASK=
