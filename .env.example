# 研报系统配置

# 服务器配置
HOST=0.0.0.0
PORT=8080

# 数据库
DATABASE_URL=sqlite+aiosqlite:///C:/Projects/research_report_system/data/reports.db

# PDF存储路径
PDF_STORAGE_PATH=C:/Projects/research_report_system/data/pdfs

# 慧博投研账号（可选，注册后填入可获取更多研报）
HUIBOR_USERNAME=
HUIBOR_PASSWORD=

# Claude API（可选，用于生成摘要）
ANTHROPIC_API_KEY=

# 定时任务
SCHEDULER_HOUR=6
SCHEDULER_MINUTE=0

# 日志级别
LOG_LEVEL=INFO