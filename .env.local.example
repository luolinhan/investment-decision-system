# Task-05: 统一配置项命名规范
# 百炼 API 配置
BAILIAN_API_KEY=your_bailian_api_key
BAILIAN_BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# 海外研报模块专用配置
FOREIGN_RESEARCH_MODEL=glm-5
FOREIGN_RESEARCH_TIMEOUT_SECONDS=45
FOREIGN_RESEARCH_RETENTION_DAYS=180

# Task-06: SSL验证配置（默认开启，仅在证书问题时关闭）
HTTP_VERIFY_SSL=true

# 服务端口（可选）
PORT=8080
